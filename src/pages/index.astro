---
export const prerender = true;
import BaseLayout from '../components/layout/BaseLayout.astro';
import ToolCard from '../components/ui/ToolCard.astro';
import BlogCard from '../components/ui/BlogCard.astro';
import JsonLd from '../components/seo/JsonLd.astro';

const toolsA = [
  {
    title: '提案文AIジェネレーター',
    description: '案件情報を貼るだけで300〜500文字の提案文をAIが自動生成。クラウドソーシング・直営業に対応。',
    href: '/tools/proposal-writer/',
    emoji: '⚡',
    badge: 'AI',
  },
  {
    title: 'フリーランス単価診断',
    description: '職種・経験年数・スキルを入力するだけで適正時間単価レンジと市場ポジションを診断。',
    href: '/tools/rate-checker/',
    emoji: '📊',
    badge: '無料',
  },
  {
    title: 'クライアントワークテンプレート集',
    description: '要件確認シート・見積書・契約前チェックリスト・納品メールなど5種のテンプレートを収録。',
    href: '/tools/client-templates/',
    emoji: '📝',
    badge: '無料',
  },
];

const toolsB = [
  {
    title: '請求書ジェネレーター',
    description: 'インボイス制度対応の請求書をPDF生成。会員登録不要・データはブラウザ内のみ。',
    href: '/tools/invoice/',
    emoji: '📄',
    badge: '無料',
  },
  {
    title: '手取り・税金シミュレーター',
    description: '年間売上を入力するだけで所得税・住民税・国保・年金・手取り額をリアルタイム計算。',
    href: '/tools/tax-simulator/',
    emoji: '💰',
    badge: '無料',
  },
  {
    title: '経費判定チェックリスト',
    description: '「これって経費にできる？」をカテゴリ別に○△×で即判定。按分率の目安も表示。',
    href: '/tools/expense-checker/',
    emoji: '✅',
    badge: '無料',
  },
];

const recentPosts = [
  {
    title: 'インボイス制度対応の請求書の書き方【2026年最新】',
    description: '適格請求書の書き方と、インボイス登録が必要かどうかの判断基準を解説します。',
    href: '/blog/invoice-guide/',
    date: '2026-03-20',
    tags: ['請求書', 'インボイス'],
  },
  {
    title: 'フリーランスの税金入門｜所得税・住民税・国保の基本',
    description: 'フリーランスが払う税金・社会保険料の種類と計算の仕組みをわかりやすく解説。',
    href: '/blog/tax-basics/',
    date: '2026-03-18',
    tags: ['税金', '確定申告'],
  },
  {
    title: '経費で落とせるもの・落とせないもの完全版',
    description: 'フリーランスが経費として計上できる費用と判断が難しいグレーゾーンを解説します。',
    href: '/blog/expense-tips/',
    date: '2026-03-15',
    tags: ['経費', '節税'],
  },
];
---

<BaseLayout
  title="フリーランスジム｜案件獲得をAIでブーストする"
  description="フリーランス・個人事業主のための無料ツール集。提案文AI・単価診断・請求書・税金シミュレーターなど6ツールを提供。会員登録不要。"
>
  <JsonLd
    type="WebSite"
    data={{
      name: 'フリーランスジム',
      url: 'https://freelance.kolomua.com',
      description: 'フリーランスの「仕事を取る」を、AIでブーストする。',
    }}
  />

  <!-- ヒーロー -->
  <section class="bg-gradient-to-br from-indigo-600 via-indigo-700 to-purple-700 text-white py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <div class="text-6xl mb-6">💪</div>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold leading-tight mb-4">
        案件獲得を、AIでブーストしよう。
      </h1>
      <p class="text-indigo-100 text-lg sm:text-xl leading-relaxed mb-8">
        提案文AI・単価診断・請求書・税金シミュレーター...<br class="hidden sm:block" />
        フリーランスの実務を無料ツールで支援します。
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/tools/" class="bg-white text-indigo-700 font-bold px-8 py-3 rounded-xl hover:bg-indigo-50 transition-colors">
          ツールを使ってみる →
        </a>
        <a href="/download/" class="border border-white/50 text-white font-medium px-8 py-3 rounded-xl hover:bg-white/10 transition-colors">
          💾 オフライン版を購入（¥5,000）
        </a>
      </div>
    </div>
  </section>

  <!-- 案件獲得ツール -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="mb-8">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-2xl">🔥</span>
        <h2 class="text-2xl font-extrabold text-gray-900">案件獲得・クライアントワーク</h2>
      </div>
      <p class="text-gray-500 text-sm ml-9">提案・単価・クライアント対応をサポート</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {toolsA.map(tool => <ToolCard {...tool} />)}
    </div>
  </section>

  <!-- 税務・事務ツール -->
  <section class="bg-gray-50 py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-8">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-2xl">🧾</span>
          <h2 class="text-2xl font-extrabold text-gray-900">税務・事務</h2>
        </div>
        <p class="text-gray-500 text-sm ml-9">請求書・税金・経費の面倒な実務をサクッと片付ける</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {toolsB.map(tool => <ToolCard {...tool} />)}
      </div>
    </div>
  </section>

  <!-- ダウンロード版 CTA -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="bg-gradient-to-r from-indigo-900 to-purple-900 rounded-2xl p-8 text-white flex flex-col sm:flex-row items-center justify-between gap-6">
      <div>
        <div class="flex items-center gap-2 mb-2">
          <span class="text-2xl">💾</span>
          <h2 class="text-xl font-extrabold">ダウンロード版（全6ツール）</h2>
        </div>
        <p class="text-indigo-200 text-sm leading-relaxed">
          オフラインで使える・回数制限なし・データはあなたのPCのみ<br />
          提案文AIは自分のAPIキーで無制限に利用可能
        </p>
      </div>
      <div class="flex-shrink-0 text-center">
        <p class="text-3xl font-extrabold mb-1">¥5,000</p>
        <p class="text-indigo-300 text-xs mb-3">税込・買い切り</p>
        <a
          href="/download/"
          class="inline-block bg-white text-indigo-700 font-bold px-6 py-2.5 rounded-xl hover:bg-indigo-50 transition-colors"
        >
          詳しく見る →
        </a>
      </div>
    </div>
  </section>

  <!-- 新着記事 -->
  <section class="bg-white py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-extrabold text-gray-900">新着記事</h2>
        <a href="/blog/" class="text-indigo-600 hover:underline text-sm font-medium">すべて見る →</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {recentPosts.map(post => <BlogCard {...post} />)}
      </div>
    </div>
  </section>
</BaseLayout>

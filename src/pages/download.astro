---
export const prerender = true;
import BaseLayout from '../components/layout/BaseLayout.astro';
import JsonLd from '../components/seo/JsonLd.astro';
---

<BaseLayout
  title="全ツールオフライン版｜フリーランスジム"
  description="フリーランスジムの全6ツールをオフラインで使えるダウンロード版。¥5,000の買い切り。回数制限なし・データはあなたのPCのみ。"
>
  <JsonLd
    type="Organization"
    data={{
      name: 'フリーランスジム ダウンロード版',
      description: '全6ツールをオフラインで使えるスタンドアロン版',
      offers: {
        '@type': 'Offer',
        price: '5000',
        priceCurrency: 'JPY',
      },
    }}
  />

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- ヒーロー -->
    <div class="text-center mb-12">
      <div class="text-5xl mb-4">💾</div>
      <h1 class="text-3xl font-extrabold text-gray-900 mb-3">
        フリーランスジム<br />ツールセット ダウンロード版
      </h1>
      <p class="text-gray-500 text-lg">全6ツールをオフラインで。一度買えばずっと使える。</p>
    </div>

    <!-- ベネフィット -->
    <div class="bg-indigo-50 border border-indigo-100 rounded-2xl p-6 mb-8">
      <ul class="space-y-3">
        {[
          { icon: '✅', text: 'オフラインで使える（インターネット不要）' },
          { icon: '✅', text: '回数制限なし（提案文AIも自分のAPIキーで無制限）' },
          { icon: '✅', text: 'データは完全にあなたのPC内（プライバシー保護）' },
          { icon: '✅', text: '一度買えばずっと使える（買い切り）' },
          { icon: '✅', text: 'ブラウザで開くだけ（インストール不要・Windows/Mac対応）' },
        ].map(item => (
          <li class="flex items-center gap-3">
            <span class="text-xl flex-shrink-0">{item.icon}</span>
            <span class="text-indigo-900 font-medium">{item.text}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- 含まれるツール -->
    <div class="bg-white border border-gray-200 rounded-2xl p-6 mb-8">
      <h2 class="font-bold text-lg text-gray-900 mb-4">含まれるツール（6種）</h2>
      <div class="space-y-3">
        {[
          { emoji: '⚡', name: '提案文AIジェネレーター', note: '自分のAnthropicAPIキーを設定して使用' },
          { emoji: '📊', name: 'フリーランス単価診断', note: '' },
          { emoji: '📝', name: 'クライアントワークテンプレート集', note: '' },
          { emoji: '📄', name: '請求書ジェネレーター', note: 'PDF出力対応' },
          { emoji: '💰', name: '手取り・税金シミュレーター', note: 'グラフ付き' },
          { emoji: '✅', name: '経費判定チェックリスト', note: '' },
        ].map(tool => (
          <div class="flex items-center gap-3 py-2 border-b border-gray-100 last:border-0">
            <span class="text-2xl">{tool.emoji}</span>
            <div>
              <p class="font-medium text-gray-900">{tool.name}</p>
              {tool.note && <p class="text-xs text-gray-400">{tool.note}</p>}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Web版との比較 -->
    <div class="mb-8">
      <h2 class="font-bold text-lg text-gray-900 mb-4">Web版との違い</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-gray-100">
              <th class="border border-gray-200 px-4 py-2 text-left">項目</th>
              <th class="border border-gray-200 px-4 py-2 text-center">Web版（無料）</th>
              <th class="border border-gray-200 px-4 py-2 text-center bg-indigo-50 text-indigo-700">ダウンロード版（¥5,000）</th>
            </tr>
          </thead>
          <tbody>
            {[
              { label: 'オフライン利用', web: '❌', dl: '✅' },
              { label: '提案文AIの回数', web: '1日30回まで', dl: '無制限（自分のAPIキー）' },
              { label: 'データ保存先', web: 'ブラウザ内', dl: 'ローカルファイル' },
              { label: 'アップデート', web: '自動', dl: '再ダウンロード' },
            ].map(row => (
              <tr>
                <td class="border border-gray-200 px-4 py-2 text-gray-700">{row.label}</td>
                <td class="border border-gray-200 px-4 py-2 text-center text-gray-500">{row.web}</td>
                <td class="border border-gray-200 px-4 py-2 text-center bg-indigo-50 font-medium text-indigo-700">{row.dl}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- 購入ボタン -->
    <div class="bg-gradient-to-r from-indigo-600 to-purple-600 rounded-2xl p-8 text-white text-center mb-8">
      <p class="text-4xl font-extrabold mb-1">¥5,000</p>
      <p class="text-indigo-200 text-sm mb-6">税込・買い切り・Gumroadで安全に決済</p>
      <a
        href="#"
        class="inline-block bg-white text-indigo-700 font-bold text-lg px-10 py-3.5 rounded-xl hover:bg-indigo-50 transition-colors"
      >
        購入する → （準備中）
      </a>
      <p class="text-indigo-300 text-xs mt-4">
        ※ Web版は無料でご利用いただけます。<br />
        ※ 提案文AIは別途 Anthropic APIキーが必要です（1回約0.6円）
      </p>
    </div>

    <!-- FAQ -->
    <div>
      <h2 class="font-bold text-lg text-gray-900 mb-4">よくある質問</h2>
      <div class="space-y-4">
        {[
          {
            q: 'Web版と何が違いますか？',
            a: '最大の違いはオフライン利用と回数無制限です。Web版は無料で使えますが提案文AIに回数制限があります。ダウンロード版は自分のAPIキーを使うため制限がありません。',
          },
          {
            q: 'APIキーって何ですか？どう取得しますか？',
            a: 'Anthropic（Claude）のAPIキーです。console.anthropic.com でアカウントを作成し、APIキーを発行してください。提案文AI以外のツールはAPIキー不要です。',
          },
          {
            q: 'どんな環境で動きますか？',
            a: 'HTMLファイルをブラウザ（Chrome, Safari, Edge等）で開くだけで動作します。Windows / Mac / Linux 対応。インストール不要です。',
          },
          {
            q: 'アップデートはありますか？',
            a: '税制改正や機能追加の際に新バージョンを同価格または無料で提供予定です。Gumroadのライブラリからダウンロードしてください。',
          },
          {
            q: '返金はできますか？',
            a: 'デジタルコンテンツの性質上、原則返金はお受けできません。ご不明点はご購入前にお問い合わせください。',
          },
        ].map(faq => (
          <details class="bg-white border border-gray-200 rounded-xl">
            <summary class="px-5 py-4 font-medium text-gray-900 cursor-pointer hover:bg-gray-50 rounded-xl">
              Q. {faq.q}
            </summary>
            <div class="px-5 pb-4 text-sm text-gray-600 leading-relaxed">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>

    <!-- Web版誘導 -->
    <div class="mt-10 text-center">
      <p class="text-gray-500 text-sm mb-3">まずはWeb版（無料）でお試しください</p>
      <a href="/tools/" class="text-indigo-600 hover:underline font-medium">
        → 無料ツール一覧を見る
      </a>
    </div>
  </div>
</BaseLayout>

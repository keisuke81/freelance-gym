---
interface Props {
  type: 'WebSite' | 'SoftwareApplication' | 'Article' | 'Organization';
  data: Record<string, unknown>;
}

const { type, data } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': type,
  ...data,
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
